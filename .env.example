# LexiScan Auto Configuration

# Project Settings
PROJECT_NAME=LexiScan Auto
VERSION=1.0.0
ENVIRONMENT=development

# Paths
DATA_DIR=./data
MODEL_DIR=./models
LOG_DIR=./logs

# OCR Settings
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGE=eng
OCR_DPI=300
OCR_CONFIDENCE_THRESHOLD=60

# Model Settings
SPACY_MODEL=en_core_web_sm
MAX_SEQUENCE_LENGTH=512
BATCH_SIZE=32
EPOCHS=50
LEARNING_RATE=0.001

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
MAX_UPLOAD_SIZE=10485760  # 10MB

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance
ENABLE_GPU=false
NUM_THREADS=4
